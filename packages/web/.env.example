# Cognito officine pool — public IDs (extractable from bundle, not secrets)
VITE_COGNITO_OFFICINE_POOL_ID=eu-central-1_PLACEHOLDER
VITE_COGNITO_OFFICINE_CLIENT_ID=PLACEHOLDER
VITE_COGNITO_REGION=eu-central-1

# API base URL — production by default; .env.local can override for local dev
VITE_API_BASE_URL=https://api.garageos.aifollyadvisor.com
