NODE_ENV=development
PORT=3100
LOG_LEVEL=debug
APP_VERSION=dev

# AWS region — required as of PR 7 because the auth plugin derives the
# Cognito JWKS URI + issuer from this together with the pool IDs below.
# In Lambda this is provided automatically by the runtime.
AWS_REGION=eu-central-1

# Supabase connection strings. Mirror of packages/database/.env.example —
# the api runtime reads DATABASE_URL to open the Prisma pool; DIRECT_URL
# is optional here and only used by the Prisma CLI (migrations / studio).
#
# Local dev: copy this file to .env (gitignored) and fill in real values
# from Supabase dashboard → Project Settings → Database. Production:
# injected from AWS Secrets Manager at Lambda cold start.
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Cognito user pool configuration (PR 7). Two pools — officine (tenant
# users) and clienti (customer end-users). IDs come from the CDK stack
# output after deploying the infrastructure; for local dev they can
# point at a dedicated sandbox pool.
COGNITO_OFFICINE_POOL_ID="eu-central-1_REPLACEME"
COGNITO_OFFICINE_CLIENT_ID="<officine-client-id>"
COGNITO_CLIENTI_POOL_ID="eu-central-1_REPLACEME"
COGNITO_CLIENTI_CLIENT_ID="<clienti-client-id>"

# Optional JWKS URL overrides. Leave unset in production (the plugin
# derives the URL from pool id + region). Useful for pointing a local
# dev server at a staging / sandbox Cognito pool, or for integration
# tests in environments that need to hit a custom JWKS URI.
# COGNITO_OFFICINE_JWKS_URL_OVERRIDE=
# COGNITO_CLIENTI_JWKS_URL_OVERRIDE=

# --- Local TLS verification (optional, prod-only flow) ---
# By default local dev runs against a local/Testcontainers Postgres
# where TLS is either disabled or self-signed and `sslmode` is omitted
# from DATABASE_URL — no extra config needed. This var is only
# relevant if you want to run the local API against the prod Supabase
# pooler with proper CA verification:
#   1. Download the CA cert from
#      https://supabase.com/dashboard/project/_/settings/database
#   2. Save it as packages/api/.local/supabase-ca.crt (gitignored)
#   3. Uncomment the line below
#   4. Set DATABASE_URL to the prod pooler URL with sslmode=verify-full
# NODE_EXTRA_CA_CERTS=./.local/supabase-ca.crt
