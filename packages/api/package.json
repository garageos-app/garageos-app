{
  "name": "@garageos/api",
  "version": "0.1.0",
  "private": true,
  "description": "GarageOS backend — Fastify on AWS Lambda via Lambda Web Adapter",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.5"
  }
}
