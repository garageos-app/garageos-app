{
  "name": "@garageos/api",
  "version": "0.1.0",
  "private": true,
  "description": "GarageOS backend — Fastify on AWS Lambda via @fastify/aws-lambda adapter",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1041.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@garageos/database": "workspace:*",
    "aws-jwt-verify": "^5.1.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.5"
  }
}
