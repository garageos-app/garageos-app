{
  "expo": {
    "name": "GarageOS",
    "slug": "garageos-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "garageos",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.garageos.mobile",
      "supportsTablet": false
    },
    "android": {
      "package": "it.garageos.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Consenti a GarageOS di usare la camera per scansionare il QR del tag veicolo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
