# Cognito platform-admins pool — public IDs (extractable from bundle, not secrets)
VITE_COGNITO_PLATFORM_ADMINS_POOL_ID=eu-central-1_PLACEHOLDER
VITE_COGNITO_PLATFORM_ADMINS_CLIENT_ID=PLACEHOLDER

# API base URL — production by default; .env.local can override for local dev
VITE_API_BASE_URL=https://api.garageos.aifollyadvisor.com
