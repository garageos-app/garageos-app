# npm-style flat node_modules. Required by the React Native / Expo toolchain
# (Metro resolves transitive deps like react-native -> invariant via flat
# layout; EAS builders do a clean install where pnpm's isolated layout breaks
# the bundle step). pnpm ignores non-root .npmrc files in a workspace, so this
# MUST live at the repo root, not in packages/mobile.
node-linker=hoisted
