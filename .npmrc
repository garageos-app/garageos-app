# Expose all packages at the root node_modules (in addition to pnpm's
# isolated layout) so Metro on EAS builders can resolve react-native's
# transitive deps (e.g. `invariant`) during the bundle step. Full
# node-linker=hoisted is NOT viable here: web pins react 19 while mobile
# pins react 18.3.1 (Expo SDK 52), and a flat tree mixes the two
# ("Invalid hook call" in web tests). shamefully-hoist keeps per-package
# resolution intact. pnpm ignores non-root .npmrc files in a workspace,
# so this MUST live at the repo root.
shamefully-hoist=true
