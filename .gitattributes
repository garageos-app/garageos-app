# Default: auto-detect text files and normalize LF on commit
* text=auto eol=lf

# Explicit text files
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf

# Windows-specific files (keep CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary

# Keep PEM/CRT files LF-normalized so Node's TLS parser sees the
# canonical line endings regardless of host OS (Windows checkout
# would otherwise rewrite to CRLF on autocrlf=true).
*.crt text eol=lf
*.pem text eol=lf
